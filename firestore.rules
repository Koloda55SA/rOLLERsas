rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /transactions/{txId} {
      allow read, write: if true;
    }
    match /daily_expenses/{dateKey} {
      allow read, write: if true;
    }
    match /shifts/{dateKey} {
      allow read, write: if true;
    }
    match /voices/{name} {
      allow read, write: if true;
    }
  }
}
